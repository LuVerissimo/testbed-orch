# Adjust for your local .env.

# AWS (local dev — LocalStack uses these dummy values)─
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
DYNAMODB_TABLE_NAME=device-reservations \
DYNAMODB_ENDPOINT_URL=http://localhost:4566 \

# PostgreSQL
POSTGRES_USER=testorch
POSTGRES_PASSWORD=testorch
POSTGRES_DB=testorch

# LocalStack
LOCALSTACK_DEBUG=0

# Service config
ASSET_MANAGER_GRPC_HOST=localhost
ASSET_MANAGER_GRPC_PORT=50051